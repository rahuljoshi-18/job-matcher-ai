// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  RECRUITER
  CANDIDATE
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
}

// ─────────────────────────────────────────────
// Core models
// ─────────────────────────────────────────────

model Domain {
  id         String   @id @default(cuid())
  name       String
  domainName String   @unique
  publicKey  String?
  signature  String?
  verified   Boolean  @default(false)
  disabled   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users       User[]
  jobs        Job[]
  invitations Invitation[]

  @@index([domainName])
  @@map("domains")
}

model User {
  id                String   @id // Clerk ID as primary key
  email             String   @unique
  role              Role     @default(CANDIDATE)
  domainId          String?
  skills            String[] @default([])  // legacy array — kept for backwards compat; prefer CandidateSkill relation
  yearsOfExperience Int?
  resumeUrl         String?  // Supabase Storage URL
  resumeRawText     String?  // Extracted PDF text
  embeddingStatus   String?  // "pending" | "ready" | "failed"
  profileHash       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  domain             Domain?                  @relation(fields: [domainId], references: [id])
  applications       Application[]
  experiences        CandidateExperience[]
  education          CandidateEducation[]
  certifications     CandidateCertification[]
  candidateSkills    CandidateSkill[]
  candidateEmbedding CandidateEmbedding?

  @@index([email])
  @@index([domainId])
  @@map("users")
}

model Job {
  id             String    @id @default(cuid())
  title          String
  description    String
  requiredSkills String[]
  domainId       String
  status         JobStatus @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  domain       Domain        @relation(fields: [domainId], references: [id])
  applications Application[]
  jobEmbedding JobEmbedding?

  @@index([domainId])
  @@index([status])
  @@map("jobs")
}

model Application {
  id            String            @id @default(cuid())
  jobId         String
  userId        String
  matchingScore Float?
  aiReasoning   String?
  status        ApplicationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // CASCADE: deleting a Job or User removes orphaned applications
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@map("applications")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      Role     @default(RECRUITER)
  domainId  String
  status    String   @default("PENDING") // "PENDING" | "ACCEPTED" | "EXPIRED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  domain Domain @relation(fields: [domainId], references: [id])

  @@index([email])
  @@index([domainId])
  @@map("invitations")
}

// ─────────────────────────────────────────────
// Normalized candidate profile tables
// ─────────────────────────────────────────────

model CandidateExperience {
  id          String    @id @default(cuid())
  candidateId String
  company     String
  role        String
  startDate   DateTime?
  endDate     DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_experiences")
}

model CandidateEducation {
  id             String   @id @default(cuid())
  candidateId    String
  institution    String
  degree         String?
  field          String?
  graduationYear Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_education")
}

model CandidateCertification {
  id          String   @id @default(cuid())
  candidateId String
  name        String
  issuer      String?
  year        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_certifications")
}

model CandidateSkill {
  id          String   @id @default(cuid())
  candidateId String
  name        String
  level       String?  // "beginner" | "intermediate" | "advanced" | "expert"
  createdAt   DateTime @default(now())

  user User @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, name])
  @@index([candidateId])
  @@map("candidate_skills")
}

// ─────────────────────────────────────────────
// Embedding tables (vector stored as Bytes, cast to vector(1536) via raw SQL)
// ─────────────────────────────────────────────

model CandidateEmbedding {
  id             String   @id @default(cuid())
  candidateId    String   @unique
  embedding      Unsupported("vector(768)")  // native pgvector column; managed via raw SQL
  embeddingModel String   @default("text-embedding-004")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_embeddings")
}

model JobEmbedding {
  id             String   @id @default(cuid())
  jobId          String   @unique
  embedding      Unsupported("vector(768)")  // native pgvector column; managed via raw SQL
  embeddingModel String   @default("text-embedding-004")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_embeddings")
}
