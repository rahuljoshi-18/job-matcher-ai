# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Prisma supports PostgreSQL, MySQL, SQLite, SQL Server, and CockroachDB
# For PostgreSQL with connection pooling (recommended for production):
# postgresql://user:password@host:port/database?pgbouncer=true

# Connection URL for application (pooled connection)
DATABASE_URL="postgresql://postgres:password@localhost:5432/job_matcher?pgbouncer=true"

# Direct URL for migrations (unpooled - use when DATABASE_URL is pooled)
DIRECT_URL="postgresql://postgres:password@localhost:5432/job_matcher"

# ============================================================================
# CLERK AUTHENTICATION CONFIGURATION
# ============================================================================
# Get these from https://dashboard.clerk.com/

# Public key for frontend (safe to expose in browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Secret key for server-side operations (KEEP SECRET - DO NOT EXPOSE)
CLERK_SECRET_KEY=sk_test_your_secret_here

# Webhook secret for Clerk events (KEEP SECRET)
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Comma-separated platform admin emails.
# Any matching signed-in user is treated as SUPER_ADMIN.
ADMIN_EMAILS=admin@example.com,owner@example.com

# ============================================================================
# CLERK URL CONFIGURATION
# ============================================================================
# URLs for Clerk sign-in/sign-up flows and redirects

# Sign-in page URL
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# Sign-up page URL
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Redirect URL after successful sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard

# Redirect URL after successful sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Full application URL (for Clerk redirects, email links, etc.)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API base URL (defaults to /api if not set)
# Development: http://localhost:3000/api
# Production: https://yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================================================
# NOTES
# ============================================================================
# 1. NEXT_PUBLIC_* variables are exposed to the browser - never put secrets here
# 2. CLERK_SECRET_KEY should NEVER be exposed to the client
# 3. For local development, use a local PostgreSQL database
# 4. For production, use connection pooling and environment-specific values
# 5. Keep .env.local in .gitignore to protect sensitive credentials

# ============================================================================
# AI PROVIDER CONFIGURATION
# ============================================================================

# Groq API key — used for PDF resume parsing and AI match reasoning
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini is used for generating Vector Embeddings (Semantic Search)
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# SUPABASE STORAGE CONFIGURATION
# ============================================================================
# Used for resume PDF uploads (bucket: "resumes", private access)
# Get from: https://supabase.com/dashboard/project/<project>/settings/api

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (server-side only — KEEP SECRET — full bucket access)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key

